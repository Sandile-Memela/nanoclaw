ASSISTANT_HAS_OWN_NUMBER=

# ── Thrive iOS channel ────────────────────────────────────────────────────────
# RabbitMQ connection string (amqp://user:pass@host:5672)
RABBITMQ_URL=
# Omega's stable session ID in Thrive (auto-generated on first run if blank)
THRIVE_OMEGA_SESSION_ID=
# Omega's Appwrite user ID (used for sent-copy receipts; leave blank if Omega has no account)
THRIVE_OMEGA_USER_ID=
# Appwrite endpoint, e.g. https://cloud.appwrite.io/v1
THRIVE_APPWRITE_ENDPOINT=
# Appwrite project ID
THRIVE_APPWRITE_PROJECT_ID=
# Appwrite server API key with Functions execute permissions
THRIVE_APPWRITE_API_KEY=
# ID of the deployed RabbitMQ Appwrite function
THRIVE_APPWRITE_FUNCTION_ID=
